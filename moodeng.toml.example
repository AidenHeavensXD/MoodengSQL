# MoodengSQL server configuration
# Copy to moodeng.toml and adjust as needed.

[server]
host = "0.0.0.0"
port = 5432
max_connections = 100
# tls_cert = "/path/to/cert.pem"
# tls_key = "/path/to/key.pem"
# require_tls = false

[storage]
data_dir = "./moodeng_data"
# max_cached_pages = 64
# rows_per_page = 16

[log]
level = "info"

[auth]
# Generate with: moodengsql hash-password "your-password"
# Or set MOODENG_PASSWORD env at runtime (hashed on startup).
password_hash = ""
# SCRAM-SHA-256 for libpq / psql clients (moodengsql hash-password --scram)
password_scram = ""
